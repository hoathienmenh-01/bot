# Telegram bot
BOT_TOKEN=
SHOP_NAME=NIMO SHOP PREMIUM
ADMIN_IDS=123456789
SUPPORT_CONTACT=@your_support_username
DATABASE_PATH=data/shop.db

# Expiration
DEPOSIT_EXPIRES_MINUTES=15
ORDER_EXPIRES_MINUTES=15

# Vietnamese bank / SePay
BANK_ENABLED=false
SEPAY_API_KEY=
SEPAY_POLL_SECONDS=30
BANK_BIN=970436
BANK_ACCOUNT=0123456789
BANK_OWNER=PHAM XUAN TOI
BANK_NAME=Vietcombank

# Binance Pay merchant
BINANCE_PAY_ENABLED=false
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
BINANCE_PAY_RETURN_URL=
BINANCE_PAY_WEBHOOK_URL=
BINANCE_PAY_ID=
BINANCE_PAY_NOTE=
USDT_BEP20_ADDRESS=
USDT_BEP20_TOLERANCE=0.02
USDT_NETWORK=BEP20
# BẮT BUỘC khi dùng webhook public: chuỗi bí mật mạnh để từ chối request giả.
# Tạo bằng: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SHARED_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET

# Web Admin
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
WEB_SESSION_SECRET=CHANGE_ME_RANDOM_32_BYTES_OR_LONGER
# Bật true khi chạy sau HTTPS/reverse proxy production.
WEB_COOKIE_SECURE=false
WEB_DEFAULT_LANGUAGE=vi
WEB_DEFAULT_THEME=light

# Delivery
# auto = đơn nhỏ hiện trong chat, đơn lớn gửi file; file_only = mọi đơn đều gửi file; inline_and_file = hiện chat và gửi kèm file
DELIVERY_OUTPUT_MODE=auto
DELIVERY_FILE_THRESHOLD=20
LOW_STOCK_THRESHOLD=5
PREORDER_DEPOSIT_PERCENT=10
STOCK_DUPLICATE_POLICY=allow
API_PUBLIC_BASE_URL=http://127.0.0.1:8080
